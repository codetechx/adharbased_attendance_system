# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_KEY=

# ─── Database ────────────────────────────────────────────────────────────────
DB_DATABASE=attendance_db
DB_USERNAME=ams_user
DB_PASSWORD=ams_secret
DB_ROOT_PASSWORD=root_secret

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost/api
FRONTEND_TARGET=dev

# ─── PDF Service ─────────────────────────────────────────────────────────────
PDF_SERVICE_URL=http://pdf-service:8001

# ─── Biometric Agent (local Windows service) ─────────────────────────────────
VITE_BIOMETRIC_WS=ws://localhost:12345
