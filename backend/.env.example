APP_NAME="AMS"
APP_ENV=local
APP_KEY=REPLACE_ME
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_IN

APP_MAINTENANCE_DRIVER=file

# ── PHP ────────────────────────────────────────────────────────────────────────
PHP_CLI_SERVER_WORKERS=4

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=attendance_db
DB_USERNAME=ams_user
DB_PASSWORD=ams_secret

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=ams_

# ── Queue ─────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@ams.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── Filesystem ────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# Aadhaar PDFs and fingerprint data stored on private disk
# In production, switch to S3:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-south-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1

# ── AMS Services ──────────────────────────────────────────────────────────────
PDF_SERVICE_URL=http://pdf-service:8001
PDF_SERVICE_TIMEOUT=60

# Biometric agent runs on the local Windows machine (not in Docker)
# host.docker.internal resolves to Windows host from inside Docker
BIOMETRIC_AGENT_URL=ws://host.docker.internal:12345
